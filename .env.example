# ── Arc network ────────────────────────────────────────────────────────────
# From the ARC CLI output / docs.arc.network. USDC is the gas token on Arc.
ARC_RPC_URL=
ARC_CHAIN_ID=5042002            # observed on Arc Testnet — CONFIRM for your net
ARC_EXPLORER_URL=               # block explorer base, e.g. https://explorer...

# USDC token on Arc testnet (from developers.circle.com) — CONFIRM
USDC_ADDRESS=

# ── Wallets / keys ─────────────────────────────────────────────────────────
AGENT_PRIVATE_KEY=              # the KERYX agent wallet (pays tolls, settles)
AGENT_WALLET_ID=                # Circle wallet/balance id (for Gateway batches)
WRITER_ADDRESS=                 # used by scripts/one-payout.js
PAYOUT_AMOUNT=0.0005

# ── KeryxSplits contract ───────────────────────────────────────────────────
KERYX_CONTRACT_ADDRESS=         # set after scripts/deploy.js
KERYX_ARTIFACT=out/KeryxSplits.sol/KeryxSplits.json

# ── x402 (the toll) ────────────────────────────────────────────────────────
X402_NETWORK=arc-testnet        # CONFIRM exact network id for the facilitator
X402_FACILITATOR_URL=           # Circle x402 facilitator URL
PUBLISHER_ADDRESS=              # wallet the fetch toll pays
PUBLISHER_BASE_URL=             # e.g. http://localhost:4000 (enables x402 fetch)

# ── Circle Gateway (the payout rail) ───────────────────────────────────────
CIRCLE_API_KEY=
GATEWAY_API_BASE=https://api.circle.com/v1/gateway   # CONFIRM
SETTLE_MODE=onchain             # 'onchain' (verifiable receipts) | 'gateway' (batched)

# ── Agent ──────────────────────────────────────────────────────────────────
ANSWER_BUDGET_USDC=0.0100
RETRIEVE_K=5
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# ── Server / data ──────────────────────────────────────────────────────────
PORT=4000
CORPUS_FILE=data/corpus.json
WORKS_SEED=data/works.seed.json
